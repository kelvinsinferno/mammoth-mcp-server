    "llm-tools"
  ],
  "author": "Kelvinsinferno Studio",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@mammoth-protocol/sdk": "file:../mammoth-sdk",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana/web3.js": "^1.95.0",
    "hono": "^4.12.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kelvinsinferno/mammoth-mcp-server.git"
  }
